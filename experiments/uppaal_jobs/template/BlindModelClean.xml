	<template>
		<name>heater_model</name>
		<declaration>double heater_temp;

void update_heat() {
    if (T_a &lt; 12) {
        heater_temp = 77;
    } else if (-12 &lt; T_a &amp;&amp; T_a &lt;= 5) {
        heater_temp = -T_a + 65;
    } else if (5 &lt; T_a &amp;&amp; T_a &lt;= 20) {
        heater_temp = -1.33 * T_a + 66.67;
    } else if (20 &lt; T_a) {
        heater_temp = 40;
    }
    T_h = heater_temp - T_r;
}</declaration>
