		<declaration>double ventilation_valve = 0.3;

void update_vent() {
    double ventilation_temp = T_a;
    if (T_a &lt;= 5){
        ventilation_temp = 21;
    } 
    else if (5 &lt; T_a &lt;= 17.8){
        ventilation_temp = -0.25 * T_a + 22.25;
    }

    T_v = ventilation_valve * (ventilation_temp - T_r);
}
